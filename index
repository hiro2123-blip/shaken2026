<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>車検予約システム２０２６</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: sans-serif; font-weight: bold; }
        .selected-day { background-color: #3b82f6 !important; color: white !important; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen p-2 text-[10px]">
    <div id="app" class="bg-white rounded-2xl shadow p-4 max-w-5xl mx-auto font-bold">
        <div class="flex justify-between items-center mb-6 border-b pb-4 text-center font-bold">
            <h1 class="text-base" onclick="location.reload()">🏪 車検予約システム２０２６</h1>
            <div class="flex space-x-2 font-bold">
                <button onclick="showSection('course-section')" class="px-3 py-1 bg-gray-100 rounded font-bold">新規</button>
                <button onclick="checkAdmin()" class="px-3 py-1 bg-gray-100 rounded font-bold">管理</button>
            </div>
        </div>
        <div id="main-content">
            <div id="course-section" class="view-section text-center py-10 font-bold">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 font-bold">
                    <button onclick="selectCourse('スタンダード')" class="border-2 p-6 rounded-2xl font-bold">⏱️ スタンダード</button>
                    <button onclick="selectCourse('セーフティ')" class="border-2 p-6 rounded-2xl font-bold">🛡️ セーフティ</button>
                    <button onclick="selectCourse('一般整備')" class="border-2 p-6 rounded-2xl font-bold">🔧 一般整備</button>
                </div>
            </div>
            <div id="form-section" class="view-section hidden font-bold">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 font-bold">
                    <div class="space-y-4 font-bold">
                        <div class="border rounded-xl p-3 bg-white font-bold">
                            <div class="flex justify-between items-center mb-2 bg-slate-700 text-white p-1 rounded font-bold"><button onclick="moveMonth(-1)">＜</button><span id="cal-m"></span><button onclick="moveMonth(1)">＞</button></div>
                            <div id="cal-grid" class="grid grid-cols-7 gap-1 text-center font-bold"></div>
                        </div>
                        <div class="grid grid-cols-3 gap-2 text-center font-bold">
                            <div class="border p-1 rounded font-bold"><button onclick="document.getElementById('f1').click()" class="bg-blue-50 w-full py-1 rounded text-[8px] font-bold">受付表</button><input type="file" id="f1" class="hidden" onchange="imgP(this,1)"><img id="i1" class="mt-1 mx-auto max-h-12 hidden"></div>
                            <div class="border p-1 rounded font-bold"><button onclick="document.getElementById('f2').click()" class="bg-blue-50 w-full py-1 rounded text-[8px] font-bold">車検証</button><input type="file" id="f2" class="hidden" onchange="imgP(this,2)"><img id="i2" class="mt-1 mx-auto max-h-12 hidden"></div>
                            <div class="border p-1 rounded font-bold"><button onclick="document.getElementById('f3').click()" class="bg-blue-50 w-full py-1 rounded text-[8px] font-bold">自賠責</button><input type="file" id="f3" class="hidden" onchange="imgP(this,3)"><img id="i3" class="mt-1 mx-auto max-h-12 hidden"></div>
                        </div>
                    </div>
                    <div class="space-y-3 font-bold">
                        <select id="sel-ss" class="w-full border p-2 rounded font-bold"><option value="">店舗選択</option><option value="板橋ss">板橋ss</option><option value="志村ss">志村ss</option><option value="小茂根ss">小茂根ss</option><option value="赤羽西ss">赤羽西ss</option><option value="東坂下ss">東坂下ss</option><option value="高島平ss">高島平ss</option><option value="武蔵関ss">武蔵関ss</option><option value="車検課">車検課</option></select>
                        <input type="text" id="u-name" class="w-full border p-2 rounded font-bold" placeholder="お名前">
                        <input type="text" id="u-num" class="w-full border p-2 rounded font-bold" placeholder="ナンバー">
                        <input type="text" id="u-memo" class="w-full border p-2 rounded font-bold" placeholder="備考">
                        <div class="p-3 bg-blue-50 rounded font-bold leading-relaxed"><p id="disp-c" class="border-b mb-1 font-bold"></p><p id="row-s">車検：<span id="date-s" class="text-blue-600 font-bold">未選択</span></p><p id="row-a">入庫：<span id="date-a" class="text-orange-600 font-bold">未選択</span></p></div>
                        <button onclick="send()" class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold">予約を送信する</button>
                    </div>
                </div>
            </div>
            <div id="admin-section" class="view-section hidden font-bold font-bold font-bold"><div id="list-area" class="overflow-x-auto font-bold"><table class="w-full border text-center font-bold"><thead class="bg-blue-500 text-white font-bold"><tr><th class="p-1 font-bold">日付</th><th class="p-1 font-bold">店舗</th><th class="p-1 font-bold">名前</th></tr></thead><tbody id="list-body" class="divide-y font-bold"></tbody></table></div></div>
        </div>
    </div>
    <script>
        const GAS_URL = "https://script.google.com/macros/s/AKfycbwHwRaPY32J8U2XpdXWOFIy6fbu4SMHFBMPGLYJbsl3YcQyk9iXHeaRacLdy74oXuL3/exec"; 
        let curC = '', selS = '', selA = '', vD = new Date(), pics = {1:"",2:"",3:""};
        const HOLS = ["2026/1/1","2026/1/12","2026/2/11","2026/2/23","2026/3/20","2026/4/29","2026/5/3","2026/5/4","2026/5/5","2026/5/6","2026/7/20","2026/8/11","2026/9/21","2026/9/22","2026/9/23","2026/10/12","2026/11/3","2026/11/23"];

        function imgP(input, n) {
            if (input.files && input.files[0]) {
                const r = new FileReader();
                r.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        let w = img.width, h = img.height, max = 800;
                        if (w > h && w > max) { h *= max/w; w = max; } else if (h > max) { w *= max/h; h = max; }
                        canvas.width = w; canvas.height = h;
                        canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                        pics[n] = canvas.toDataURL('image/jpeg', 0.7);
                        document.getElementById(`i${n}`).src = pics[n];
                        document.getElementById(`i${n}`).classList.remove('hidden');
                    };
                    img.src = e.target.result;
                };
                r.readAsDataURL(input.files[0]);
            }
        }

        function selectCourse(n) { curC = n; document.getElementById('disp-c').innerText = n; document.getElementById('row-s').classList.toggle('hidden', n==='一般整備'); document.getElementById('row-a').classList.toggle('hidden', n==='スタンダード'); renderCal(); showSection('form-section'); }
        function renderCal() {
            const grid = document.getElementById('cal-grid'); grid.innerHTML = '';
            const y = vD.getFullYear(), m = vD.getMonth();
            document.getElementById('cal-m').innerText = `${y}年 ${m+1}月`;
            ['日','月','火','水','木','金','土'].forEach(d => grid.insertAdjacentHTML('beforeend', `<div class="text-gray-400 font-bold">${d}</div>`));
            const f = new Date(y, m, 1).getDay(), l = new Date(y, m+1, 0).getDate();
            for(let i=0; i<f; i++) grid.appendChild(document.createElement('div'));
            for(let i=1; i<=l; i++) {
                const k = `${y}/${m+1}/${i}`, dO = new Date(y, m, i);
                const isH = dO.getDay()===0 || dO.getDay()===6 || HOLS.includes(k);
                const div = document.createElement('div');
                div.className = `p-1 border rounded h-8 flex items-center justify-center font-bold ${isH?'text-red-300':'hover:bg-blue-50 cursor-pointer'}`;
                div.innerHTML = i;
                div.onclick = () => { document.querySelectorAll('#cal-grid div').forEach(d => d.classList.remove('selected-day')); div.classList.add('selected-day'); if (curC==='一般整備') { selA = k; selS = ""; } else { selS = k; selA = (curC==='セーフティ') ? getPrevBiz(k) : ""; } document.getElementById('date-s').innerText = selS || '-'; document.getElementById('date-a').innerText = selA || '-'; };
                grid.appendChild(div);
            }
        }
        function getPrevBiz(ds) { let d = new Date(ds); do { d.setDate(d.getDate()-1); } while (d.getDay()===0||d.getDay()===6||HOLS.includes(`${d.getFullYear()}/${d.getMonth()+1}/${d.getDate()}`)); return `${d.getFullYear()}/${d.getMonth()+1}/${d.getDate()}`; }
        async function send() { const data = { shakenDate: selS, arrivalDate: selA, ss: document.getElementById('sel-ss').value, course: curC, name: document.getElementById('u-name').value, carNum: document.getElementById('u-num').value, memo: document.getElementById('u-memo').value, photo1: pics[1], photo2: pics[2], photo3: pics[3] }; try { await fetch(GAS_URL, {method:"POST", mode:"no-cors", body:JSON.stringify(data)}); alert('送信完了'); location.reload(); } catch(e) { alert('エラー'); } }
        function showSection(id) { document.querySelectorAll('.view-section').forEach(s => s.classList.add('hidden')); document.getElementById(id).classList.remove('hidden'); }
        function moveMonth(d) { vD.setMonth(vD.getMonth() + d); renderCal(); }
        function checkAdmin() { if (prompt("PW") === "ss1234") { showSection('admin-section'); fetch(GAS_URL + "?action=getData").then(res => res.json()).then(data => { const b = document.getElementById('list-body'); b.innerHTML = ''; data.forEach(r => { b.insertAdjacentHTML('beforeend', `<tr><td class="p-1">${r.shakenDate || r.arrivalDate}</td><td class="p-1">${r.ss}</td><td class="p-1">${r.name}</td></tr>`); }); }); } }
    </script>
</body>
</html>
